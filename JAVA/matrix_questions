    public static void Questao11() {

        int Dl,Dc,i,j;

        System.out.print("Digite a Dimensão da Linha:");
        Dl = sc.nextInt();
        System.out.print("Digite a Dimensão da Coluna:");
        Dc = sc.nextInt();
        int[][]matriz=new int[Dl][Dc];
        System.out.printf("Digite os Valores da Matriz de %d X %d com %d Elementos:\n", Dl, Dc, Dl * Dc);
        for(i=0;i<Dl;i++)
            for(j=0;j<Dc;j++)
                matriz[i][j]=sc.nextInt();
        System.out.println("Matriz Completa");
        for(i=0;i<Dl;i++) {
            for(j=0;j<Dc;j++)
                System.out.printf("%3d ",matriz[i][j]);
            System.out.println();
        }
        if(Dl == Dc){
            System.out.println("Elementos da Diagonal Secundária:");
            for(i=0;i<Dl;i++)
                System.out.println(matriz[i][Dc-1-i]);
        }else{
            System.out.println("Não Possui Diagonal Secundária");
        }
    }

    public static void Questao12() {

        int i,j,k;
        int[][]m1=new int[3][3];
        int[][]m2=new int[3][3];
        int[][]m3=new int[3][3];

        System.out.println("Digite os Valores da Primeira Matriz:");
        for(i=0;i<3;i++)
            for(j=0;j<3;j++)
                m1[i][j]=sc.nextInt();
        System.out.println("Digite os Valores da Segunda Matriz:");
        for(i=0;i<3;i++)
            for(j=0;j<3;j++)
                m2[i][j]=sc.nextInt();
        for(i=0;i<3;i++)
            for(j=0;j<3;j++)
                for(k=0;k<3;k++)
                    m3[i][j]+=m1[i][k]*m2[k][j];
        System.out.printf("Matriz 1:\n");
        for(i=0;i<3;i++){
            for(j=0;j<3;j++)
                System.out.printf("%3d ",m1[i][j]);
            System.out.println();
        }
        System.out.printf("Matriz 2:\n");
        for(i=0;i<3;i++){
            for(j=0;j<3;j++)
                System.out.printf("%3d ",m2[i][j]);
            System.out.println();
        }
        System.out.println("Resultado M1 x M2:");
        for(int[]linha:m3) {
            for(int val:linha)
                System.out.printf("%3d ",val);
            System.out.println();
        }
    }

