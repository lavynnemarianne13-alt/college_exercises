            System.out.println("Erro! A matriz deve ser quadrada");
            return;
        }
        int[][] matriz = new int[Dl][Dc];
        System.out.printf("Digite os valores da matriz de %d x %d (%d elementos):\n", Dl, Dc, Dl * Dc);
        for (i=0;i<Dl;i++) {
            for (j=0;j<Dc;j++) {
                matriz[i][j]=sc.nextInt();
            }
        }
        System.out.println("Matriz dividida por 2:");
        for (i=0;i<Dl;i++) {
            for (j=0;j<Dc;j++) {
                System.out.printf("%3d ",matriz[i][j]/2);
            }
            System.out.println();
        }
    }

